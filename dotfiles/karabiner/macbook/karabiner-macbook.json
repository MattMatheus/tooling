{
  "title": "MacBook Base Config",
  "rules": [
    {
      "description": "Caps Lock → Hyper Key (Ctrl+Opt+Cmd+Shift) on hold",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_shift",
              "modifiers": [
                "left_control",
                "left_option",
                "left_command"
              ]
            }
          ],
          "conditions": []
        }
      ]
    }
  ]
}
