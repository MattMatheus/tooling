{
  "vim_mode": false,
  "format_on_save": "on",
  "tab_size": 2,
  "hard_tabs": false,
  "relative_line_numbers": false,
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "autosave": "off",
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark"
  },
  "keymap": [
    {
      "context": "Workspace",
      "bindings": {
        "ctrl-alt-shift-v": "editor::ToggleVimMode"
      }
    }
  ]
}
